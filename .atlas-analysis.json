  "keyFeatures": [
    "Pattern-based static analysis that matches code semantically, not just textually",
    "Support for 30+ programming languages including Python, Java, JavaScript, Go, Ruby, C, and more",
    "Metavariable syntax ($X, $...) for flexible pattern matching without AST knowledge",
    "Taint analysis for tracking data flow from sources to sinks",
    "Autofix capability for automatic code remediation",
    "CI/CD integration with GitHub Actions, GitLab CI, and more",
    "MCP (Model Context Protocol) server for AI coding assistant integration",
    "SAST, SCA (Supply Chain), and Secrets scanning capabilities",
    "Pre-commit hook support for scanning code before commits",
    "Output in multiple formats: JSON, SARIF, GitLab SAST, JUnit XML, and text"
  ],
  "publicApiSurface": [
    "semgrep scan",
    "semgrep ci",
    "semgrep login",
    "semgrep logout",
    "semgrep publish",
    "semgrep mcp",
    "semgrep install-semgrep-pro",
    "--config / -c (rule configuration)",
    "--pattern / -e (inline pattern)",
    "--lang / -l (language)",
    "--output / -o (output file)",
    "--json (JSON output format)",
    "--sarif (SARIF output format)",
    "--autofix (apply fixes)",
    "--severity (filter by severity)",
    "--include / --exclude (file filtering)",
    "--metrics (telemetry control)"
  ]
}
